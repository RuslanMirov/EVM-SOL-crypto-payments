# ─── HD Wallet ───────────────────────────────────────────────────────────────
# BIP-39 mnemonic — NEVER commit the real one
HD_MNEMONIC="word1 word2 word3 ... word12"

# ─── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=crypto_pay
DB_CONNECTION_LIMIT=10

# ─── EVM chains ──────────────────────────────────────────────────────────────
# Add as many chains as needed using the pattern:
#   EVM_CHAIN_{chainId}_RPC   — JSON-RPC endpoint
#   EVM_CHAIN_{chainId}_BASE  — treasury address that receives swept funds
#   EVM_CHAIN_{chainId}_NAME  — human label (for logs)

# Ethereum mainnet
EVM_CHAIN_1_RPC=https://mainnet.infura.io/v3/YOUR_KEY
EVM_CHAIN_1_BASE=0xYOUR_TREASURY
EVM_CHAIN_1_NAME=Ethereum

# BNB Smart Chain
EVM_CHAIN_56_RPC=https://bsc-dataseed.binance.org
EVM_CHAIN_56_BASE=0xYOUR_TREASURY
EVM_CHAIN_56_NAME=BSC

# Polygon
EVM_CHAIN_137_RPC=https://polygon-rpc.com
EVM_CHAIN_137_BASE=0xYOUR_TREASURY
EVM_CHAIN_137_NAME=Polygon

# ─── EVM derivation ──────────────────────────────────────────────────────────
# All EVM-compatible chains share coin type 60 (standard MetaMask path)
EVM_DERIVATION_PATH=m/44'/60'/0'/0

# ─── Solana ──────────────────────────────────────────────────────────────────
# RPC endpoint (e.g. Helius, QuickNode, or default mainnet-beta)
SOL_RPC=https://api.mainnet-beta.solana.com
# Treasury public key (base58) — receives swept funds
SOL_TREASURY=YOUR_SOL_TREASURY_PUBKEY
# Treasury private key (JSON array format) — needed for SPL token gas seeding
# SOL_TREASURY_PRIVATE_KEY=[1,2,3,...,64]

# ─── Monitor ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=15000
EVM_CONFIRMATIONS=2
SOL_CONFIRMATIONS=2

# ─── Payment TTL ─────────────────────────────────────────────────────────────
DEFAULT_TTL_MS=1800000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth ────────────────────────────────────────────────────────────────
# Bearer token for the /api/payments/* endpoints (pay-history, verify-payment)
API_BEARER_TOKEN=change-me-to-a-secure-random-string
